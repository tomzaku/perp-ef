#!/bin/sh

# Auto-increment patch version in package.json on each commit
# Version format: x.y.z — increments z by 1

PACKAGE="package.json"

if [ ! -f "$PACKAGE" ]; then
  exit 0
fi

# Read current version
VERSION=$(grep '"version"' "$PACKAGE" | sed 's/.*"version": *"\([^"]*\)".*/\1/')

if [ -z "$VERSION" ]; then
  exit 0
fi

# Split into major.minor.patch
MAJOR=$(echo "$VERSION" | cut -d. -f1)
MINOR=$(echo "$VERSION" | cut -d. -f2)
PATCH=$(echo "$VERSION" | cut -d. -f3)

# Increment patch
NEW_PATCH=$((PATCH + 1))
NEW_VERSION="$MAJOR.$MINOR.$NEW_PATCH"

# Update package.json in place
sed -i '' "s/\"version\": \"$VERSION\"/\"version\": \"$NEW_VERSION\"/" "$PACKAGE"

# Stage the updated package.json
git add "$PACKAGE"
